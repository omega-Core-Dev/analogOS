   "source": [
    "# 🧠 analogOS — Input Interativo\n",
    "> `scan → broadcast → candidate → propagate → compose`\n",
    "\n",
    "Alimente seus próprios pares P/R e veja como o pipeline se sai com seus dados inferidos."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-install",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CÉLULA 1: Dependências ─────────────────────────────────────────────────\n",
    "!pip install numpy scikit-learn ipywidgets --quiet\n",
    "from IPython.display import display, clear_output\n",
    "import ipywidgets as widgets\n",
    "import numpy as np\n",
    "import math, re, time\n",
    "print('✅ Dependências OK')"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-primitives",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CÉLULA 2: Primitivas analogOS (self-contained) ─────────────────────────\n",
    "\n",
    "def tokenize(text):\n",
    "    return re.findall(r'\\w+', text.lower())\n",
    "\n",
    "def scan(memory):\n",
    "    \"\"\"Percorre entidades da memória e cria mapa id→par.\"\"\"\n",
    "    return {f'e{i+1}': pair for i, pair in enumerate(memory)}\n",
    "\n",
    "def broadcast(query_tokens, entity_map):\n",
    "    \"\"\"Emite sinal de similaridade entre query e cada entidade.\"\"\"\n",
    "    q_set = set(query_tokens)\n",
    "    signals = {}\n",
    "    for eid, pair in entity_map.items():\n",
    "        p_tokens = set(tokenize(pair['p']))\n",
    "        overlap = len(q_set & p_tokens)\n",
    "        union   = len(q_set | p_tokens)\n",
    "        signals[eid] = overlap / union if union else 0.0\n",
    "    return signals\n",
    "\n",
    "def candidate(signals, threshold=0.05):\n",
    "    \"\"\"Filtra entidades acima do threshold.\"\"\"\n",
    "    return {eid: s for eid, s in signals.items() if s >= threshold}\n",
    "\n",
    "def propagate(candidates, entity_map, use_counts):\n",
    "    \"\"\"Repassa sinal com reforço por frequência de uso.\"\"\"\n",
    "    if not candidates:\n",
    "        return {}\n",
    "    max_sig = max(candidates.values())\n",
    "    weights = {}\n",
    "    for eid, sig in candidates.items():\n",
    "        reinforcement = 1 + math.log(1 + use_counts.get(eid, 0))\n",
    "        weights[eid] = (sig / max_sig) * reinforcement\n",
    "    return weights\n",
    "\n",
    "def compose(weights, entity_map):\n",
    "    \"\"\"Retorna o par mais pesado (top-1 weighted sum).\"\"\"\n",
    "    if not weights:\n",
    "        return None, None\n",
    "    top = max(weights, key=weights.get)\n",
    "    return entity_map[top], weights[top]\n",
    "\n",
    "# ── Intenção simples ────────────────────────────────────────────────────────\n",
    "INTENT_KEYWORDS = {\n",
    "    'DEFINIR':   ['o que', 'define', 'definir', 'significa', 'conceito', 'é'],\n",
    "    'CONSTRUIR': ['como', 'implementar', 'criar', 'construir', 'fazer', 'funciona'],\n",
    "    'COMPARAR':  ['diferença', 'comparar', 'vs', 'versus', 'melhor', 'entre'],\n",
    "    'VALIDAR':   ['faz sentido', 'correto', 'está certo', 'valida', 'confirma'],\n",
    "    'EXPLORAR':  ['e se', 'o que acontece', 'explorar', 'testar', 'simular'],\n",
    "}\n",
    "\n",
    "def detect_intent(query):\n",
    "    q = query.lower()\n",
    "    scores = {intent: sum(1 for kw in kws if kw in q)\n",
    "              for intent, kws in INTENT_KEYWORDS.items()}\n",
    "    best = max(scores, key=scores.get)\n",
    "    conf = min(scores[best] / 3, 1.0)\n",
    "    return best, round(conf, 2)\n",
    "\n",
    "print('✅ Primitivas OK')"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-memory",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CÉLULA 3: Seed de memória — EDITE COM SEUS DADOS ──────────────────────\n",
    "#\n",
    "#  Adicione pares P/R que representam seu domínio inferido.\n",
    "#  O pipeline vai aprender a recuperar análogos a partir deles.\n",
    "\n",
    "SEED_MEMORY = [\n",
    "    # ── exemplos análogos analogOS (podem ser substituídos) ──\n",
    "    {'p': 'O que é scan?',\n",
    "     'r': 'scan() percorre entidades e cria um mapa id→objeto.'},\n",
    "\n",
    "    {'p': 'Como funciona broadcast?',\n",
    "     'r': 'broadcast() emite sinal de similaridade entre a query e cada entidade.'},\n",
    "\n",
    "    {'p': 'O que é candidate?',\n",
    "     'r': 'candidate() filtra entidades acima do threshold de sinal.'},\n",
    "\n",
    "    {'p': 'Como propagate cria clusters?',\n",
    "     'r': 'propagate() repassa sinal para vizinhos — clusters emergem naturalmente.'},\n",
    "\n",
    "    {'p': 'O que compose faz?',\n",
    "     'r': 'compose() agrega os sinais ponderados e retorna a saída final.'},\n",
    "\n",
    "    {'p': 'Como as primitivas mapeiam atenção?',\n",
    "     'r': 'scan=tokens, broadcast=query, candidate=keys>=threshold, propagate=values, compose=weighted_sum.'},\n",
    "\n",
    "    # ── ADICIONE SEUS PARES ABAIXO ──\n",
    "    # {'p': 'Sua pergunta aqui', 'r': 'Sua resposta / dado inferido aqui'},\n",
    "]\n",
    "\n",
    "# Estado da sessão\n",
    "session_memory = list(SEED_MEMORY)\n",
    "use_counts     = {}   # reforço por frequência\n",
    "history        = []   # log da sessão\n",
    "\n",
    "print(f'✅ Memória carregada: {len(session_memory)} pares')"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-pipeline",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CÉLULA 4: Função de resposta do pipeline ───────────────────────────────\n",
    "\n",
    "def run_pipeline(query, threshold=0.05, verbose=True):\n",
    "    tokens  = tokenize(query)\n",
    "    intent, conf = detect_intent(query)\n",
    "\n",
    "    # Pipeline\n",
    "    emap    = scan(session_memory)\n",
    "    sigs    = broadcast(tokens, emap)\n",
    "    cands   = candidate(sigs, threshold)\n",
    "    weights = propagate(cands, emap, use_counts)\n",
    "    top_pair, top_weight = compose(weights, emap)\n",
    "\n",
    "    # Atualiza uso\n",
    "    if weights:\n",
    "        top_id = max(weights, key=weights.get)\n",
    "        use_counts[top_id] = use_counts.get(top_id, 0) + 1\n",
    "\n",
    "    result = {\n",
    "        'query':      query,\n",
    "        'intent':     intent,\n",
    "        'conf':       conf,\n",
    "        'n_cands':    len(cands),\n",
    "        'top_pair':   top_pair,\n",
    "        'top_weight': round(top_weight, 4) if top_weight else 0,\n",
    "        'all_weights': {k: round(v,3) for k,v in sorted(\n",
    "                            weights.items(), key=lambda x: -x[1])[:5]},\n",
    "    }\n",
    "\n",
    "    if verbose:\n",
    "        sep = '─' * 60\n",
    "        print(sep)\n",
    "        print(f'INPUT    : {query}')\n",
    "        print(f'Intenção : {intent} (conf={conf})')\n",
    "        print(f'Candidatos: {len(cands)} / {len(emap)}')\n",
    "        if top_pair:\n",
    "            print(f'Par análogo: [{intent}] peso={top_weight:.3f}')\n",
    "            print(f'  P: {top_pair[\"p\"]}')\n",
    "            print(f'  R: {top_pair[\"r\"]}')\n",
    "        else:\n",
    "            print('⚠️  Nenhum análogo encontrado (threshold muito alto?)')\n",
    "        print(sep)\n",
    "\n",
    "    history.append(result)\n",
    "    return result\n",
    "\n",
    "print('✅ Pipeline pronto')"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-interactive",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CÉLULA 5: Interface Interativa ─────────────────────────────────────────\n",
    "\n",
    "out = widgets.Output(layout={'border': '1px solid #333', 'padding': '10px',\n",
    "                              'min_height': '200px', 'font_family': 'monospace'})\n",
    "\n",
    "txt_input = widgets.Text(\n",
    "    placeholder='Digite sua pergunta aqui...',\n",
    "    layout=widgets.Layout(width='70%')\n",
    ")\n",
    "\n",
    "slider_threshold = widgets.FloatSlider(\n",
    "    value=0.05, min=0.0, max=0.5, step=0.01,\n",
    "    description='Threshold:', readout_format='.2f',\n",
    "    layout=widgets.Layout(width='50%')\n",
    ")\n",
    "\n",
    "btn_run    = widgets.Button(description='▶ Consultar',\n",
    "                             button_style='primary',\n",
    "                             layout=widgets.Layout(width='120px'))\n",
    "btn_learn  = widgets.Button(description='＋ Aprender',\n",
    "                             button_style='success',\n",
    "                             layout=widgets.Layout(width='120px'))\n",
    "btn_clear  = widgets.Button(description='🗑 Limpar log',\n",
    "                             button_style='warning',\n",
    "                             layout=widgets.Layout(width='120px'))\n",
    "btn_status = widgets.Button(description='📊 Status',\n",
    "                             button_style='info',\n",
    "                             layout=widgets.Layout(width='120px'))\n",
    "\n",
    "txt_learn_p = widgets.Text(placeholder='Nova pergunta (P)',\n",
    "                            layout=widgets.Layout(width='45%'))\n",
    "txt_learn_r = widgets.Text(placeholder='Resposta / dado inferido (R)',\n",
    "                            layout=widgets.Layout(width='45%'))\n",
    "\n",
    "# ── Callbacks ──────────────────────────────────────────────────────────────\n",
    "\n",
    "def on_run(_):\n",
    "    q = txt_input.value.strip()\n",
    "    if not q:\n",
    "        return\n",
    "    with out:\n",
    "        run_pipeline(q, threshold=slider_threshold.value)\n",
    "\n",
    "def on_enter(evt):\n",
    "    on_run(None)\n",
    "\n",
    "def on_learn(_):\n",
    "    p = txt_learn_p.value.strip()\n",
    "    r = txt_learn_r.value.strip()\n",
    "    if not p or not r:\n",
    "        with out:\n",
    "            print('⚠️  Preencha P e R antes de aprender.')\n",
    "        return\n",
    "    session_memory.append({'p': p, 'r': r})\n",
    "    txt_learn_p.value = ''\n",
    "    txt_learn_r.value = ''\n",
    "    with out:\n",
    "        print(f'✅ Par aprendido. Memória: {len(session_memory)} pares.')\n",
    "\n",
    "def on_clear(_):\n",
    "    out.clear_output()\n",
    "\n",
    "def on_status(_):\n",
    "    with out:\n",
    "        print('\\n📊 STATUS DA SESSÃO')\n",
    "        print(f'   Memória total : {len(session_memory)} pares')\n",
    "        print(f'   Consultas     : {len(history)}')\n",
    "        print('   Top usados:')\n",
    "        emap = scan(session_memory)\n",
    "        for eid, cnt in sorted(use_counts.items(), key=lambda x: -x[1])[:5]:\n",
    "            p_preview = emap[eid]['p'][:50] if eid in emap else '?'\n",
    "            print(f'     {eid}  uso={cnt}  | {p_preview}')\n",
    "        if history:\n",
    "            print('   Última consulta:', history[-1]['query'])\n",
    "        print()\n",
    "\n",
    "btn_run.on_click(on_run)\n",
    "btn_learn.on_click(on_learn)\n",
    "btn_clear.on_click(on_clear)\n",
    "btn_status.on_click(on_status)\n",
    "txt_input.on_submit(on_enter)\n",
    "\n",
    "# ── Layout ─────────────────────────────────────────────────────────────────\n",
    "display(\n",
    "    widgets.HTML('<h3>🧠 analogOS — Consulta Interativa</h3>'),\n",
    "    widgets.HBox([txt_input, btn_run, btn_clear, btn_status]),\n",
    "    slider_threshold,\n",
    "    widgets.HTML('<b>Aprender novo par:</b>'),\n",
    "    widgets.HBox([txt_learn_p, txt_learn_r, btn_learn]),\n",
    "    widgets.HTML('<hr><b>Output:</b>'),\n",
    "    out\n",
    ")\n",
    "with out:\n",
    "    print('Sessão pronta. Digite uma pergunta e clique ▶ Consultar.')"
   ]
  },

